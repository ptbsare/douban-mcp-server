{
  "name": "douban-mcp",
  "version": "0.3.0",
  "description": "Douban MCP server - search books, movies, TV shows, group topics from Douban",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "douban-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "package.json",
    "README.md"
  ],
  "publishConfig": {
