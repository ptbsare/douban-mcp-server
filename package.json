    "dayjs": "^1.11.13",
    "json2md": "^2.0.2",
    "open": "^10.1.0",
    "turndown": "^7.2.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/turndown": "^5.0.5",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
